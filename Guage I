<!DOCTYPE html>
<html>
<head>
    <title>X-PRO DIESEL MASTER</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <style>
        body { background: #0a0a0a; color: #00ff00; font-family: 'Courier New', monospace; margin: 0; overflow: hidden; height: 100vh; display: flex; flex-direction: column; }
        #gauge-area { height: 35vh; position: relative; display: flex; justify-content: center; align-items: center; border-bottom: 2px solid #333; }
        svg { width: 80%; height: 80%; transform: rotate(-90deg); }
        #track { fill: none; stroke: #222; stroke-width: 10; }
        #needle { fill: none; stroke: #0f0; stroke-width: 12; stroke-dasharray: 0 1000; transition: stroke-dasharray 0.2s; stroke-linecap: round; }
        #readout { position: absolute; top: 55%; left: 50%; transform: translate(-50%, -50%); text-align: center; }
        #rpm-val { font-size: 50px; font-weight: bold; }
        #console { height: 20vh; background: #000; padding: 8px; overflow-y: auto; font-size: 12px; color: #0ff; border-bottom: 1px solid #333; white-space: pre-wrap; box-sizing: border-box; }
        #grid { height: 45vh; display: grid; grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(4, 1fr); gap: 5px; padding: 5px 5px 85px 5px; background: #111; box-sizing: border-box; }
        button { background: #222; color: #0f0; border: 1px solid #0f0; font-size: 10px; font-weight: bold; text-transform: uppercase; border-radius: 2px; height: 100%; }
        button:active { background: #004400; color: #fff; }
        .btn-auth { border-color: #00bfff; color: #00bfff; }
        .btn-warn { border-color: orange; color: orange; }
        .btn-crit { border-color: red; color: red; }
    </style>
</head>
<body>
    <div id="gauge-area" onclick="connect()">
        <svg viewBox="0 0 200 200">
            <path id="track" d="M 40 160 A 80 80 0 1 1 160 160" />
            <path id="needle" d="M 40 160 A 80 80 0 1 1 160 160" />
        </svg>
        <div id="readout"><div id="rpm-val">0</div><div>RPM</div></div>
    </div>
    <div id="console">TAP GAUGE TO UNLOCK ECU...</div>
    <div id="grid">
        <button class="btn-auth" onclick="connect()">Connect & Unlock</button>
        <button onclick="toggleLive()">Live Stream</button>
        <button onclick="readDTC()">Check Faults</button>
        <button class="btn-crit" onclick="clearCodes()">Clear Codes</button>
        <button onclick="manual()">Manual Hex</button>
        <button onclick="downloadLog()">Upload Log</button>
        <button onclick="runCmd('22F405')">Coolant</button>
        <button onclick="runCmd('22F190')">VIN Info</button>
        <button onclick="runCmd('22110C')">Diesel RPM</button>
        <button class="btn-warn" onclick="runCmd('020000')">Freeze Frame</button>
        <button onclick="runCmd('ATRV')">Volts</button>
        <button class="btn-crit" onclick="disconnectPort()">Disconnect</button>
    </div>
<script>
let port, reader, writer, live = false, pinger;
const dec = new TextDecoder();
const enc = new TextEncoder();

function log(m) { const c = document.getElementById('console'); c.innerText += `> ${m}\n`; c.scrollTop = c.scrollHeight; }

async function runCmd(c) {
    if(!writer) return "OFFLINE";
    try {
        await writer.write(enc.encode(c + "\r"));
        let r = "";
        const timeout = Date.now() + 1500;
        while (Date.now() < timeout) {
            const { value } = await reader.read();
            r += dec.decode(value);
            if (r.includes(">")) break;
        }
        let clean = r.replace(/>/g, "").trim();
        log(c + ": " + clean);
        return clean;
    } catch(e) { return "ERR"; }
}

function startPinger() {
    if (pinger) clearInterval(pinger);
    pinger = setInterval(async () => {
        if (writer && !live) await runCmd("3E00"); 
    }, 2000);
}

async function connect() {
    try {
        port = await navigator.serial.requestPort();
        await port.open({ baudRate: 38400 });
        writer = port.writable.getWriter();
        reader = port.readable.getReader();
        
        log("INITIALIZING...");
        await runCmd("ATZ");
        await new Promise(r => setTimeout(r, 800));
        await runCmd("ATSP6");
        await runCmd("ATSH7E0");
        
        let auth = await runCmd("1003");
        if (auth.includes("5003") || auth.includes("50 03")) {
            log("EXTENDED SESSION OK");
            startPinger();
            let seedRes = await runCmd("2701");
            if (seedRes.includes("6701") || seedRes.includes("67 01")) {
                let unlock = await runCmd("270255AA");
                if (unlock.includes("6702") || unlock.includes("67 02")) {
                    log("SUCCESS: ECU UNLOCKED");
                }
            }
        }
    } catch(e) { log("CONN FAILED"); }
}

async function toggleLive() {
    live = !live;
    log(live ? "STREAM START" : "STREAM STOP");
    while(live) {
        let r = await runCmd("22110C"); // X200 style RPM PID
        if(r.includes("62")) {
            let p = r.split(" ");
            let h = p.slice(3, 5).join("");
            let v = parseInt(h, 16) / 4;
            document.getElementById('rpm-val').innerText = Math.round(v);
            document.getElementById('needle').style.strokeDasharray = `${3.8 * ((v/6500)*100)} 1000`;
        }
        await new Promise(res => setTimeout(res, 100));
    }
}

async function readDTC() { await runCmd("03"); }
async function clearCodes() { if(confirm("Clear Faults?")) await runCmd("04"); }
async function manual() { let c = prompt("HEX:"); if(c) await runCmd(c); }

async function disconnectPort() {
    if (pinger) clearInterval(pinger);
    live = false;
    if (writer) {
        writer.releaseLock();
        reader.releaseLock();
        await port.close();
        log("DISCONNECTED");
    }
}

function downloadLog() {
    const b = new Blob([document.getElementById('console').innerText], {type: 'text/plain'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(b); a.download = 'XPRO_DIESEL_LOG.txt'; a.click();
}
</script>
</body>
</html>
